u5e74\u7ea0\u7eb7\u6e0a\u6e90\uff0c\u5b70\u662f\u5b70\u975e\uff1f_\u54d4\u54e9\u54d4\u54e9_bilibili</p>"},{"location":"notes/%E4%BB%80%E4%B9%88%E6%98%AF%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD%EF%BC%9F/","title":"\u4ec0\u4e48\u662f\u6570\u5b57\u82b1\u56ed\uff1f","text":":material-circle-edit-outline: \u7ea6 1253 \u4e2a\u5b57 :material-clock-time-two-outline: \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 4 \u5206\u949f"},{"location":"notes/%E4%BB%80%E4%B9%88%E6%98%AF%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD%EF%BC%9F/#_1","title":"\u4e00\u4e9b\u4e0d\u9519\u4e2d\u6587\u89e3\u91ca","text":"<p>\u6570\u5b57\u82b1\u56ed\u662f\u4ecb\u4e8e\u4e2a\u4eba\u535a\u5ba2\u548c\u7ef4\u57fa\u4e4b\u95f4\u7684\u4e1c\u897f\u3002\u8fd9\u662f\u4e00\u4e2a\u4e0d\u65ad\u53d1\u5c55\u7684\u7b14\u8bb0\u3001\u6587\u7ae0\u548c\u60f3\u6cd5\u7684\u96c6\u5408\uff0c\u5e76\u6ca1\u6709\u4e25\u683c\u6309\u7167\u4ed6\u4eec\u7684\u53d1\u8868\u65e5\u671f\u7ec4\u7ec7\u3002\u5b83\u4eec\u672c\u8d28\u4e0a\u662f\u63a2\u7d22\u6027\u7684\u5e16\u5b50\uff0c\u662f\u901a\u8fc7\u4e0a\u4e0b\u6587\u5173\u8054\u8054\u7cfb\u8d77\u6765\u7684\u3002\u5b83\u4eec\u4e0d\u662f\u7cbe\u70bc\u7684\u3001\u6216\u5b8c\u6574\u7684\u5e16\u5b50\uff0c\u53ef\u4ee5\u4f5c\u4e3a\u534a\u6210\u54c1\u7684\u60f3\u6cd5\u53d1\u5e03\uff0c\u8fd9\u4e9b\u60f3\u6cd5\u4f1a\u968f\u7740\u65f6\u95f4\u7684\u63a8\u79fb\u800c\u589e\u957f\u548c\u6f14\u53d8\u3002\u5b83\u4eec\u6ca1\u6709\u6211\u4eec\u5728\u7f51\u7edc\u4e0a\u7ecf\u5e38\u9047\u5230\u7684\u4e2a\u4eba\u535a\u5ba2\u90a3\u4e48\u6b7b\u677f\u3001\u90a3\u4e48\u6709\u8868\u73b0\u529b\u3001\u90a3\u4e48\u5b8c\u7f8e\u3002\uff08\u6765\u6e90\uff1aBlogBomb\uff09  </p> <p>\u5176\u7279\u70b9\u5728\u4e8e\u6bcf\u4e2a\u4eba\u4ee5\u6ce8\u91cd\u8bed\u4e49\u8054\u7cfb\u7684\u62d3\u6251\u7ed3\u6784\u800c\u975e\u65f6\u95f4\u7ebf\u53d1\u5e03\u5185\u5bb9\uff0c\u901a\u8fc7\u53cc\u5411\u94fe\u63a5\u3001\u6811\u72b6\u7ed3\u6784\u3001\u56fe\u7ed3\u6784\u3001\u7d22\u5f15\u7b49\u65b9\u5f0f\u4f7f\u8bfb\u8005\u53ef\u4ee5\u4ee5\u81ea\u5df1\u7684\u65b9\u5f0f\u6d4f\u89c8\u7f51\u7ad9\u5185\u5bb9\uff1b\u5e76\u4e14\u8fd9\u4e9b\u5185\u5bb9\u5728\u521d\u6b21\u53d1\u5e03\u4e4b\u540e\u8fd8\u4f1a\u4e0d\u65ad\u4fee\u6539\u3001\u4e30\u5bcc\u3001\u5b8c\u5584\uff1b\u8fd9\u4e24\u4e2a\u7279\u70b9\u52a0\u4e0a\u4e2a\u4eba\u5316\u7684\u7279\u70b9\u7684\u4f7f\u5f97\u516c\u5171\u5b66\u4e60\u6210\u4e3a\u53ef\u80fd\u3002\uff08\u6765\u6e90\uff1a\u8c2d\u6dde\u5bb8\u7684\u77e5\u8bc6\u5e93\uff09  </p> <p>\u6570\u5b57\u82b1\u56ed\u662f\u901a\u8fc7\u501f\u52a9\u7f51\u7edc\u6570\u5b57\u5de5\u5177\uff0c\u5bf9\u60f3\u6cd5\u3001\u7b14\u8bb0\u548c\u601d\u8003\u7b49\u4e00\u5207\u4f60\u611f\u5174\u8da3\u7684\u4fe1\u606f\u6216\u8fdb\u884c\u6536\u96c6\u3001\u6574\u7406\u548c\u521b\u4f5c\uff0c\u6587\u5b57\u4e4b\u95f4\u7528\u6807\u7b7e\u6216\u94fe\u63a5\u521b\u5efa\u8fde\u63a5\uff0c\u5f62\u6210\u4e00\u5ea7\u72ec\u5177\u4e2a\u4eba\u6d53\u539a\u8272\u5f69\u7684\u4fe1\u606f\u4e0e\u77e5\u8bc6\u578b\u82b1\u56ed\u3002\u4e0d\u50cf\u7b14\u8bb0\u5185\u5bb9\u7684\u7eaf\u79c1\u4eba\u6027\u4e00\u6837\uff0c\u6570\u5b57\u82b1\u56ed\u9f13\u52b1\u7528\u6237\u53d1\u5e03\u81ea\u5df1\u7684\u60f3\u6cd5\u3001\u8349\u7a3f\uff0c\u8fd9\u5728\u5f88\u5927\u7a0b\u5ea6\u4e0a\u964d\u4f4e\u4e86\u6211\u4eec\u7684\u53d1\u5e03\u538b\u529b\u3002\u540c\u65f6\uff0c\u6570\u5b57\u82b1\u56ed\u4e0d\u50cf\u535a\u5ba2\u90a3\u6837\u5b8c\u5168\u516c\u5f00\uff0c\u4ee5\u5efa\u7acb\u4e2a\u4eba\u54c1\u724c\u4f5c\u4e3a\u5185\u5bb9\u53d1\u5e03\u7684\u4e3b\u8981\u76ee\u7684\u3002\uff08\u6765\u6e90\uff1a\ud83c\udf31 oldwinter\u306e\u6570\u5b57\u82b1\u56ed\uff09  </p>"},{"location":"notes/%E4%BB%80%E4%B9%88%E6%98%AF%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD%EF%BC%9F/#_2","title":"\u6211\u7684\u7406\u89e3","text":"<p>\u6570\u5b57\u82b1\u56ed\u662f\u4e00\u79cd\u65b0\u578b\u7684\u4e2a\u4eba\u77e5\u8bc6\u7ba1\u7406\u548c\u5206\u4eab\u65b9\u5f0f\uff0c\u5b83\u878d\u5408\u4e86\u4e2a\u4eba\u535a\u5ba2\u7684\u4e2a\u6027\u5316\u548c\u7ef4\u57fa\u7684\u5f00\u653e\u6027\u3002\u4ee5\u4e0b\u662f\u6211\u5bf9\u6570\u5b57\u82b1\u56ed\u7684\u51e0\u70b9\u7406\u89e3\uff1a  </p> <ol> <li>\u77e5\u8bc6\u7f51\u7edc\u5316\uff1a\u6570\u5b57\u82b1\u56ed\u901a\u8fc7\u53cc\u5411\u94fe\u63a5\u548c\u6807\u7b7e\u5c06\u4e0d\u540c\u7684\u4fe1\u606f\u548c\u60f3\u6cd5\u8fde\u63a5\u8d77\u6765\uff0c\u5f62\u6210\u4e00\u4e2a\u7f51\u7edc\u3002\u8fd9\u79cd\u7f51\u7edc\u5316\u7684\u77e5\u8bc6\u7ed3\u6784\u6709\u52a9\u4e8e\u6211\u4eec\u66f4\u597d\u5730\u7406\u89e3\u548c\u8bb0\u5fc6\u4fe1\u606f\uff0c\u56e0\u4e3a\u5b83\u6a21\u62df\u4e86\u4eba\u8111\u4e2d\u77e5\u8bc6\u8fde\u63a5\u7684\u65b9\u5f0f\u3002  </li> <li>\u52a8\u6001\u66f4\u65b0\uff1a\u4e0e\u4f20\u7edf\u535a\u5ba2\u76f8\u6bd4\uff0c\u6570\u5b57\u82b1\u56ed\u7684\u5185\u5bb9\u4e0d\u662f\u4e00\u6210\u4e0d\u53d8\u7684\u3002\u5b83\u53ef\u4ee5\u968f\u7740\u65f6\u95f4\u7684\u63a8\u79fb\u4e0d\u65ad\u66f4\u65b0\u548c\u5b8c\u5584\uff0c\u8fd9\u4f7f\u5f97\u5185\u5bb9\u66f4\u52a0\u9c9c\u6d3b\u548c\u6709\u751f\u547d\u529b\u3002  </li> <li>\u63a2\u7d22\u6027\u5199\u4f5c\uff1a\u6570\u5b57\u82b1\u56ed\u9f13\u52b1\u63a2\u7d22\u6027\u5199\u4f5c\uff0c\u5373\u5141\u8bb8\u53d1\u5e03\u672a\u5b8c\u5168\u6210\u719f\u7684\u60f3\u6cd5\u3002\u8fd9\u79cd\u5199\u4f5c\u65b9\u5f0f\u964d\u4f4e\u4e86\u53d1\u8868\u7684\u95e8\u69db\uff0c\u9f13\u52b1\u66f4\u591a\u7684\u601d\u8003\u548c\u521b\u4f5c\u3002  </li> <li>\u4e2a\u6027\u5c55\u793a\uff1a\u6bcf\u4e2a\u4eba\u7684\u6570\u5b57\u82b1\u56ed\u90fd\u662f\u72ec\u4e00\u65e0\u4e8c\u7684\uff0c\u5b83\u53cd\u6620\u4e86\u4e2a\u4eba\u7684\u5174\u8da3\u3001\u601d\u8003\u548c\u77e5\u8bc6\u7ed3\u6784\u3002\u8fd9\u79cd\u4e2a\u6027\u5316\u7684\u5c55\u793a\u6709\u52a9\u4e8e\u5efa\u7acb\u4e2a\u4eba\u54c1\u724c\uff0c\u540c\u65f6\u4e5f\u4e3a\u4ed6\u4eba\u63d0\u4f9b\u4e86\u4e0d\u540c\u7684\u89c6\u89d2\u548c\u89c1\u89e3\u3002  </li> <li>\u5185\u5bb9\u5f00\u653e\uff1a\u6709\u522b\u4e8e\u79c1\u4eba\u7b14\u8bb0\uff0c\u6570\u5b57\u82b1\u56ed\u7684\u5185\u5bb9\u662f\u5f00\u653e\u7684\uff0c\u8fd9\u610f\u5473\u7740\u5b83\u53ef\u4ee5\u5438\u5f15\u6765\u81ea\u4e0d\u540c\u80cc\u666f\u7684\u4eba\u8fdb\u884c\u4e92\u52a8\u548c\u53cd\u9988\u3002\u8fd9\u79cd\u4e92\u52a8\u4e0d\u4ec5\u80fd\u591f\u4fc3\u8fdb\u77e5\u8bc6\u7684\u4ea4\u6d41\uff0c\u8fd8\u80fd\u591f\u6fc0\u53d1\u65b0\u7684\u60f3\u6cd5\u548c\u7075\u611f\u3002  </li> <li>\u957f\u671f\u4ef7\u503c\uff1a\u6570\u5b57\u82b1\u56ed\u7684\u5185\u5bb9\u53ef\u4ee5\u968f\u7740\u65f6\u95f4\u7684\u63a8\u79fb\u800c\u79ef\u7d2f\u4ef7\u503c\u3002\u5b83\u4e0d\u4ec5\u662f\u4e2a\u4eba\u77e5\u8bc6\u5e93\uff0c\u4e5f\u662f\u4e2a\u4eba\u6210\u957f\u548c\u5b66\u4e60\u5386\u7a0b\u7684\u8bb0\u5f55\u3002  </li> <li>\u77e5\u8bc6\u5171\u4eab\uff1a\u6570\u5b57\u82b1\u56ed\u9f13\u52b1\u77e5\u8bc6\u7684\u5171\u4eab\uff0c\u901a\u8fc7\u516c\u5f00\u81ea\u5df1\u7684\u60f3\u6cd5\u548c\u7b14\u8bb0\uff0c\u53ef\u4ee5\u8ba9\u66f4\u591a\u7684\u4eba\u53d7\u76ca\uff0c\u540c\u65f6\u4e5f\u80fd\u591f\u4ece\u4ed6\u4eba\u7684\u53cd\u9988\u4e2d\u5b66\u4e60\u548c\u6210\u957f\u3002  </li> </ol> <p>\u8bda\u7136\uff0c\u6570\u5b57\u82b1\u56ed\u5df2\u7ecf\u6709\u4e86\u8fd9\u4e48\u591a\u7684\u89e3\u91ca\u548c\u7406\u89e3\u3002\u4f46\u6211\u8ba4\u4e3a\u5176\u6700\u6838\u5fc3\u7684\u662f\u53ef\u4ee5\u4e0d\u7528\u62d8\u6ce5\u4e8e\u5f62\u5f0f\u53bb\u5206\u4eab\u548c\u5c55\u793a\u3002\u8b6c\u5982\u672c\u7ad9\u76ee\u524d\u8fd8\u5728\u91c7\u53d6\u539f\u59cb\u7684\u76ee\u5f55\u7ed3\u6784\u7684\u5f62\u5f0f\u6765\u7ec4\u7ec7\u5185\u5bb9\uff0c\u800c\u975e\u53cc\u94fe\u4e0e\u6807\u7b7e\uff0c\u540c\u65f6\u76ee\u524d\u81ea\u5df1\u8fd8\u53ea\u80fd\u505a\u5230\u5c06\u5c11\u90e8\u5206\u79c1\u6709\u7b14\u8bb0\u642c\u8fdb\u6765\u3002\u4f46\u4ecd\u4e0d\u59a8\u788d\u6211\u5c06\u672c\u7ad9\u79f0\u4e4b\u4e3a\u300c\u6570\u5b57\u82b1\u56ed\u300d\u3002  </p>"},{"location":"notes/%E4%BB%80%E4%B9%88%E6%98%AF%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD%EF%BC%9F/#_3","title":"\u6211\u4e3a\u4ec0\u4e48\u8981\u5efa\u7acb\u300c\u6570\u5b57\u82b1\u56ed\u300d","text":"<ul> <li>\u65e0\u538b\u521b\u4f5c\uff0c\u53d1\u5e03\u7684\u5185\u5bb9\u4e0d\u9700\u8981\u975e\u5e38\u7cbe\u70bc\u5b8c\u6574\uff0c\u4e0d\u9700\u8981\u7b49\u5230\u300c\u5199\u597d\u300d\u540e\u518d\u53d1\u5e03\u3002\u6bd5\u7adf\u6bcf\u68f5\u300c\u679d\u82bd\u300d\u90fd\u662f\u9700\u8981\u957f\u671f\u300c\u4fee\u526a\u300d\u7684\u3002  </li> <li>\u5f00\u653e\u6210\u957f\uff0c\u79c1\u6709\u7b14\u8bb0\u867d\u597d\uff0c\u4f46\u59cb\u7ec8\u90fd\u662f\u81ea\u5df1\u5728\u8bb0\u5f55\u548c\u9605\u8bfb\u3002\u5f00\u653e\u51fa\u6765\u540e\u80fd\u4ea7\u751f\u4e00\u4e9b\u4ea4\u6d41\u548c\u4e92\u52a8\u3002\u8fd9\u5bf9\u4fdd\u6301\u6210\u957f\u52a8\u529b\u5f88\u91cd\u8981\u3002  </li> <li>\u957f\u671f\u4e3b\u4e49\uff0c\u4fdd\u7559\u4e00\u5757\u81ea\u7559\u5730\uff0c\u6301\u7eed\u8015\u8018\uff0c\u91cd\u65b0\u8ba4\u8bc6\u81ea\u5df1\u4e0e\u65f6\u95f4\uff0c\u5b66\u4e60\u5199\u4f5c\uff0c\u5229\u4ed6\u3001\u5206\u4eab\u3002\u770b\u4e00\u770b\u4e0b\u4e00\u4e2a\u5341\u5e74\u4f1a\u53d8\u6210\u4ec0\u4e48\u6837\u3002  </li> <li>\u5584\u7528\u4f73\u8f6f\uff0c\u5728\u8fd9\u4e2a\u751f\u4ea7\u529b\u66b4\u6da8\u7684\u65f6\u4ee3\uff0c\u6c89\u6dc0\u51fa\u4e86\u8fd9\u4e48\u591a\u7684\u4f18\u79c0\u8f6f\u4ef6\uff0c\u867d\u8bf4\u4e0d\u80fd\u4e3a\u4e86\u7528\u800c\u7528\uff0c\u4f46\u4eba\u5230\u4e2d\u5e74\uff0c\u603b\u662f\u9700\u8981\u4e00\u4e9b\u300c\u73a9\u5177\u300d\u3002  </li> </ul>"},{"location":"notes/%E5%88%A0%E9%99%A4%20Github%20%E4%BB%93%E5%BA%93%E5%85%A8%E9%83%A8%E7%9A%84%20commit%20%E8%AE%B0%E5%BD%95/","title":"\u5220\u9664 Github \u4ed3\u5e93\u5168\u90e8\u7684 commit \u8bb0\u5f55","text":"<p>\u5f53\u8fc7\u53bb commit \u8bb0\u5f55\u4e2d\u5305\u542b\u9690\u79c1\u4fe1\u606f\u540e\uff0c\u60f3\u5220\u9664\u5168\u90e8\u7684 commit \u8bb0\u5f55\uff0c\u4f46\u662f\u53c8\u4e0d\u60f3\u5220\u9664\u5e76\u91cd\u65b0\u5efa\u7acb\u4ed3\u5e93\uff08\u6709 Star\uff09\uff0c\u53ef\u4ee5\u5c06\u4ed3\u5e93 clone \u5230\u672c\u5730\u540e\u4f7f\u7528\u4ee5\u4e0b\u65b9\u6cd5\uff1a  </p> <p>\u4ee5 main \u5206\u652f\u4e3a\u4f8b\uff1a  </p> <pre><code># \u65b0\u5efa\u4e00\u4e2a\u7a7a\u767d\u5206\u652f  \n&lt;div markdown=\"1\" style=\"margin-top: -30px; font-size: 0.75em; opacity: 0.7;\"&gt;\n:material-circle-edit-outline: \u7ea6 80 \u4e2a\u5b57 :fontawesome-solid-code: 17 \u884c\u4ee3\u7801 :material-clock-time-two-outline: \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f\n&lt;/div&gt;\ngit checkout --orphan latest_branch  \n\n# \u6dfb\u52a0\u6240\u6709\u6587\u4ef6  \ngit add -A  \n\n# \u5f3a\u5236\u5220\u9664\u6240\u6709\u5206\u652f\uff0c\u5982\u679c\u662fmain  \ngit branch -D main  \n\n# \u5c06\u5f53\u524d\u5206\u652f\u547d\u540d\u4e3amain  \ngit branch -m main  \n\n# \u63d0\u4ea4commit  \ngit commit -m \"Initial commit\"  \n\n# \u5f3a\u5236\u63a8\u9001\u5230\u8fdc\u7a0b\u4ed3\u5e93  \ngit push -f origin main  \n</code></pre> <p>\u53c2\u8003\u6765\u6e90\uff1a\u5220\u9664github\u4e0a\u7684commit\u8bb0\u5f55 - \u8001\u536b\u540c\u5b66 - \u535a\u5ba2\u56ed</p>"},{"location":"notes/%E6%90%9C%E9%9B%86%E4%B8%80%E4%BA%9BMkDocs%E7%AB%99%E7%82%B9/","title":"\u641c\u96c6\u4e00\u4e9bMkDocs\u7ad9\u70b9","text":":material-circle-edit-outline: \u7ea6 116 \u4e2a\u5b57 :material-clock-time-two-outline: \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f  <p>\u6574\u7406\u4e00\u4e9b\u81ea\u5df1\u65e5\u5e38\u9047\u5230\u7684\u4f18\u79c0 MkDocs \u7ad9\u70b9\uff0c\u540e\u7eed\u6216\u8bb8\u4f1a\u4e13\u95e8\u627e\u65f6\u95f4\u6574\u7406\u4e00\u4e0b\u3002 - Material for MkDocs - Material for MkDocs \u4e2d\u6587\u6587\u6863 - ElseWhere - Mkdocs\u4e2d\u6587\u6559\u7a0b - \u7ef4\u71d5\u7684\u6570\u5b57\u82b1\u56ed - \u2606 \u9996\u9875 - \u5b09\u620f\u5b9e\u9a8c\u5ba4 - yangzhang's Site - yangzhang's Site - \u9996\u9875 - \u6cd5\u5229\u7684\u9605\u85cf\u7b14\u8bb0 - Hi! - Self-Knowing - Home - \u6d69\u54c8\u54c8\u54c8\u54c8 - Home - \u514b\u745e\u5947\uff08Chritch\uff09\u7684\u7b14\u8bb0\u672c - Xuc's Docs - Cloud Notes - index - hackettyu's blog - \u683c\u83b1\u59c6\u7684\u65e5\u5e38 - shafish.cn - \u9646\u56fd\u677e\u7684\u7f16\u7a0b\u7b14\u8bb0</p>"},{"location":"notes/%E6%90%9C%E9%9B%86%E4%B8%80%E4%BA%9B%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD%E7%AB%99%E7%82%B9/","title":"\u641c\u96c6\u4e00\u4e9b\u6570\u5b57\u82b1\u56ed\u7ad9\u70b9","text":":material-circle-edit-outline: \u7ea6 128 \u4e2a\u5b57 :material-clock-time-two-outline: \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f  <p>\u6574\u7406\u4e00\u4e9b\u81ea\u5df1\u65e5\u5e38\u9047\u5230\u7684\u4f18\u79c0\u300c\u6570\u5b57\u82b1\u56ed\u300d\uff0c\u540e\u7eed\u6216\u8bb8\u4f1a\u4e13\u95e8\u627e\u65f6\u95f4\u6574\u7406\u4e00\u4e0b\u3002  </p> <ul> <li>\u9177\u53e3\u5bb6\u6570\u5b57\u82b1\u56ed-\u7814\u7a76\u5361\u7247\u76d2\u7b14\u8bb0\u6cd5\uff0c\u6253\u9020\u7b2c\u4e8c\u5927\u8111 </li> <li>LearnData \u5f00\u6e90\u7b14\u8bb0 | LearnData \u5f00\u6e90\u7b14\u8bb0 </li> <li>AboutTheGarden </li> <li>\u6570\u5b57\u82b1\u56ed\ud83c\udf31 </li> <li>\u6570\u5b57\u82b1\u56ed </li> <li>HomePage </li> <li>\u8001\u7238\u7684\u6570\u5b57\u82b1\u56ed - Nas \u79c1\u6709\u4e91 </li> <li>\u8c2d\u6dde\u5bb8\u7684\u77e5\u8bc6\u5e93 </li> <li>Rome </li> <li>\ud83c\udfa1 \u5b66\u4e60\u8005\u7684\u6570\u5b57\u6e38\u4e50\u56ed \u2014 \u5728\u73a9\u800d\u4e2d\u5b66\u4e60 </li> <li>\u6570\u5b57\u82b1\u56ed\u5408\u96c6:\u4eff\u751f\u732b\u4e0d\u4f1a\u68a6\u89c1\u7535\u5b50\u732b\u7cae \u2014 To make each day count.</li> </ul>"},{"location":"obsidian/","title":"Obsidian","text":":material-circle-edit-outline: \u7ea6 72 \u4e2a\u5b57 :material-clock-time-two-outline: \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f"},{"location":"obsidian/#_1","title":"\u63d2\u4ef6\u5217\u8868","text":"\u6807\u9898 \u63d2\u4ef6\u7b80\u4ecb \u72b6\u6001 \u6700\u540e\u66f4\u65b0 Auto Link Title \u81ea\u52a8\u83b7\u53d6\u94fe\u63a5\u6807\u9898 \u2705 \u5728\u7528 2025-04-06 BRAT \u53ef\u5b89\u88c5\u672a\u4e0a\u67b6\u7684\u63d2\u4ef6 \u2705 \u5728\u7528 2025-04-06 File Explorer Note Count \u6587\u4ef6\u5217\u8868\u663e\u793a\u6587\u4ef6\u6570\u91cf \u2705 \u5728\u7528 2025-04-06"},{"location":"obsidian/#_2","title":