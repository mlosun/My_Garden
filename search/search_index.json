ea0\u7eb7\u6e0a\u6e90\uff0c\u5b70\u662f\u5b70\u975e\uff1f_\u54d4\u54e9\u54d4\u54e9_bilibili</p>"},{"location":"notes/%E5%80%BC%E5%BE%97%E5%AD%A6%E4%B9%A0%E7%9A%84%E6%95%B0%E5%AD%97%E8%8A%B1%E5%9B%AD/","title":"\u503c\u5f97\u5b66\u4e60\u7684\u6570\u5b57\u82b1\u56ed","text":"<p>\u6574\u7406\u4e00\u4e9b\u81ea\u5df1\u65e5\u5e38\u9047\u5230\u7684\u4f18\u79c0\u300c\u6570\u5b57\u82b1\u56ed\u300d\uff0c\u540e\u7eed\u6216\u8bb8\u4f1a\u4e13\u95e8\u627e\u65f6\u95f4\u6574\u7406\u4e00\u4e0b\u3002  </p> <ul> <li>\u9177\u53e3\u5bb6\u6570\u5b57\u82b1\u56ed-\u7814\u7a76\u5361\u7247\u76d2\u7b14\u8bb0\u6cd5\uff0c\u6253\u9020\u7b2c\u4e8c\u5927\u8111 </li> <li>LearnData \u5f00\u6e90\u7b14\u8bb0 | LearnData \u5f00\u6e90\u7b14\u8bb0 </li> <li>AboutTheGarden </li> <li>\u6570\u5b57\u82b1\u56ed\ud83c\udf31 </li> <li>\u6570\u5b57\u82b1\u56ed </li> <li>HomePage </li> <li>\u8001\u7238\u7684\u6570\u5b57\u82b1\u56ed - Nas \u79c1\u6709\u4e91 </li> <li>\u8c2d\u6dde\u5bb8\u7684\u77e5\u8bc6\u5e93 </li> <li>Rome </li> <li>\ud83c\udfa1 \u5b66\u4e60\u8005\u7684\u6570\u5b57\u6e38\u4e50\u56ed \u2014 \u5728\u73a9\u800d\u4e2d\u5b66\u4e60 </li> <li>\u6570\u5b57\u82b1\u56ed\u5408\u96c6:\u4eff\u751f\u732b\u4e0d\u4f1a\u68a6\u89c1\u7535\u5b50\u732b\u7cae \u2014 To make each day count.</li> </ul>"},{"location":"obsidian/","title":"Obsidian","text":""},{"location":"obsidian/#_1","title":"\u6700\u8fd1\u66f4\u65b0","text":"<ul> <li>\u63d2\u4ef6\uff1aEnveloppe </li> </ul>"},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/","title":"\u63d2\u4ef6\uff1aEnveloppe","text":"<p>Quartz\u4e0eEnveloppe\u63d2\u4ef6\u7ed3\u5408\u52a9\u529bObsidian\u642d\u5efa\u6570\u5b57\u82b1\u56ed </p> <p>Enveloppe </p>"},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#_1","title":"\u63d2\u4ef6\u8bbe\u7f6e","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#github-config","title":"Github config","text":"<ul> <li>API Type\uff1aFree/Pro/Team (default)\u3002  </li> <li>GitHub username\uff1aGithub \u767b\u5f55\u7684\u8d26\u6237\u540d\u3002  </li> <li>Repository name\uff1a\u9759\u6001\u7f51\u7ad9\u7684\u5b58\u50a8\u5e93\u540d\u5b57\u3002  </li> <li>GitHub token\uff1a\u5177\u6709\u64cd\u4f5c\u5b58\u50a8\u5e93\u6743\u9650\u7684 token\uff0c\u70b9\u6b64\u751f\u6210\u3002\u5176\u4e2d\uff0cscopes\u4fdd\u6301\u94fe\u63a5\u9ed8\u8ba4\u9009\u4e2d\u7684\u5373\u53ef\uff0cExpiration\u8bbe\u7f6e\u8fc7\u671f\u65f6\u95f4\uff0c\u5982\u679c\u4e0d\u60f3\u5b9a\u671f\u66f4\u6362\uff0c\u53ef\u4ee5\u9009\u62e9No expiration\u3002  </li> <li>Main branch\uff1a\u4e0a\u4f20\u7b14\u8bb0\u7684\u5206\u652f\uff0c\u9ed8\u8ba4\u4e3a main\uff0c\u76ee\u524d Quartz \u7684\u4e3b\u5206\u652f\u662fv4\u3002  </li> </ul> <p>GitHub Workflow\uff1a\u6b64\u6807\u9898\u4e0b\u7684\u9009\u9879\u4fdd\u6301\u9ed8\u8ba4\u5373\u53ef\u3002  </p>"},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#file-paths","title":"File paths","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#content","title":"Content","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#attachment-embeds","title":"Attachment &amp; embeds","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#plugin-settings","title":"Plugin settings","text":""},{"location":"tech/","title":"\u6280\u672f","text":""},{"location":"tech/#_1","title":"\u6700\u8fd1\u66f4\u65b0","text":"<ul> <li>Docker </li> <li>Linux </li> <li>Python </li> </ul>"},{"location":"tech/Docker/","title":"Docker","text":""},{"location":"tech/Docker/#_1","title":"\u5e38\u7528\u547d\u4ee4","text":"<p>\u4ec5\u5217\u51fa\u76ee\u524d\u81ea\u5df1\u5e38\u7528\u7684\uff0c\u66f4\u591a\u547d\u4ee4\u53ef\u53c2\u8003 Docker \u547d\u4ee4\u5927\u5168 | \u83dc\u9e1f\u6559\u7a0b </p> <ul> <li><code>docker ps</code> \u5217\u51fa docker \u5bb9\u5668\uff0c\u5ba2\u83b7\u53d6\u83b7\u53d6\u5bb9\u5668\u7684 ID \u548c\u540d\u79f0 </li> <li><code>docker stats</code> \u5b9e\u65f6\u663e\u793a docker \u5bb9\u5668\u7684\u8d44\u6e90\u4f7f\u7528\u60c5\u51b5 </li> <li><code>docker logs -f --tail 100 &lt;\u5bb9\u5668ID\u6216\u540d\u79f0&gt;</code> \u5b9e\u65f6\u663e\u793a\u7684 100 \u6761\u5bb9\u5668\u65e5\u5fd7 </li> <li><code>docker compose up -d</code> \u5728\u5f53\u524d\u76ee\u5f55\u4e0b\u4ee5\u540e\u53f0\u6a21\u5f0f\u8fd0\u884c <code>docker-compose.yml</code> \u5185\u5b9a\u4e49\u7684\u5bb9\u5668  </li> </ul>"},{"location":"tech/Docker/#_2","title":"\u6838\u5fc3\u6982\u5ff5","text":"<ul> <li>\u955c\u50cf\uff08Image\uff09\uff1a\u955c\u50cf\u662f Docker \u4e2d\u7684\u4e00\u4e2a\u6a21\u677f\u3002  </li> <li>\u5bb9\u5668\uff08Container\uff09\uff1a\u5bb9\u5668\u662f\u955c\u50cf\u8fd0\u884c\u65f6\u7684\u5b9e\u4f8b\u3002  </li> <li>\u4ed3\u5e93\uff08Repository\uff09\uff1a\u4ed3\u5e93\u7528\u6765\u5b58\u50a8\u955c\u50cf\u3002  </li> </ul>"},{"location":"tech/Docker/#_3","title":"\u914d\u7f6e\u6587\u4ef6","text":"<ul> <li><code>Dockerfile</code> \u5b9a\u4e49\u5982\u4f55\u6784\u5efa\u4e00\u4e2a\u955c\u50cf Docker Dockerfile | \u83dc\u9e1f\u6559\u7a0b </li> <li><code>docker-compose.yml</code> \u5b9a\u4e49\u548c\u7ba1\u7406\u4e00\u4e2a\u6216\u591a\u4e2a\u5bb9\u5668 Docker Compose | \u83dc\u9e1f\u6559\u7a0b</li> </ul>"},{"location":"tech/Linux/","title":"Linux","text":""},{"location":"tech/Linux/#_1","title":"\u5e38\u7528\u547d\u4ee4","text":"<p>\u4ec5\u5217\u51fa\u76ee\u524d\u81ea\u5df1\u5e38\u7528\u7684\uff0c\u66f4\u591a\u547d\u4ee4\u53ef\u53c2\u8003 Linux \u547d\u4ee4\u5927\u5168 | \u83dc\u9e1f\u6559\u7a0b </p> <ul> <li><code>cd &lt;\u8def\u5f84&gt;</code> \u5207\u6362\u76ee\u5f55\u5230\u8def\u5f84\u4e0b  </li> <li><code>ls</code> \u5217\u51fa\u5f53\u524d\u8def\u5f84\u4e0b\u7684\u5168\u90e8\u6587\u4ef6\u53ca\u5b50\u76ee\u5f55  </li> <li><code>clear</code> \u6e05\u9664\u7ec8\u7aef\u5c4f\u5e55  </li> <li><code>top</code> \u5b9e\u65f6\u663e\u793a\u670d\u52a1\u5668\u7cfb\u7edf\u548c\u8fdb\u7a0b\u4fe1\u606f</li> </ul>"},{"location":"tech/Python/","title":"Python","text":"<p>\u7b80\u4ecb - Python\u6559\u7a0b - \u5ed6\u96ea\u5cf0\u7684\u5b98\u65b9\u7f51\u7ad9</p>"}]}