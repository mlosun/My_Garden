6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#file-paths","title":"File paths","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#content","title":"Content","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#attachment-embeds","title":"Attachment &amp; embeds","text":""},{"location":"obsidian/%E6%8F%92%E4%BB%B6%EF%BC%9AEnveloppe/#plugin-settings","title":"Plugin settings","text":""},{"location":"tech/","title":"\u6280\u672f","text":""},{"location":"tech/#_2","title":"\u6700\u8fd1\u66f4\u65b0","text":"<ul> <li>Docker </li> <li>Linux </li> <li>Python </li> </ul>"},{"location":"tech/Docker/","title":"Docker","text":""},{"location":"tech/Docker/#_1","title":"\u5e38\u7528\u547d\u4ee4","text":"<p>\u4ec5\u5217\u51fa\u76ee\u524d\u81ea\u5df1\u5e38\u7528\u7684\uff0c\u66f4\u591a\u547d\u4ee4\u53ef\u53c2\u8003 Docker \u547d\u4ee4\u5927\u5168 | \u83dc\u9e1f\u6559\u7a0b </p> <ul> <li><code>docker ps</code> \u5217\u51fa docker \u5bb9\u5668\uff0c\u5ba2\u83b7\u53d6\u83b7\u53d6\u5bb9\u5668\u7684 ID \u548c\u540d\u79f0 </li> <li><code>docker stats</code> \u5b9e\u65f6\u663e\u793a docker \u5bb9\u5668\u7684\u8d44\u6e90\u4f7f\u7528\u60c5\u51b5 </li> <li><code>docker logs -f --tail 100 &lt;\u5bb9\u5668ID\u6216\u540d\u79f0&gt;</code> \u5b9e\u65f6\u663e\u793a\u7684 100 \u6761\u5bb9\u5668\u65e5\u5fd7 </li> <li><code>docker compose up -d</code> \u5728\u5f53\u524d\u76ee\u5f55\u4e0b\u4ee5\u540e\u53f0\u6a21\u5f0f\u8fd0\u884c <code>docker-compose.yml</code> \u5185\u5b9a\u4e49\u7684\u5bb9\u5668  </li> </ul>"},{"location":"tech/Docker/#_2","title":"\u6838\u5fc3\u6982\u5ff5","text":"<ul> <li>\u955c\u50cf\uff08Image\uff09\uff1a\u955c\u50cf\u662f Docker \u4e2d\u7684\u4e00\u4e2a\u6a21\u677f\u3002  </li> <li>\u5bb9\u5668\uff08Container\uff09\uff1a\u5bb9\u5668\u662f\u955c\u50cf\u8fd0\u884c\u65f6\u7684\u5b9e\u4f8b\u3002  </li> <li>\u4ed3\u5e93\uff08Repository\uff09\uff1a\u4ed3\u5e93\u7528\u6765\u5b58\u50a8\u955c\u50cf\u3002  </li> </ul>"},{"location":"tech/Docker/#_3","title":"\u914d\u7f6e\u6587\u4ef6","text":"<ul> <li><code>Dockerfile</code> \u5b9a\u4e49\u5982\u4f55\u6784\u5efa\u4e00\u4e2a\u955c\u50cf Docker Dockerfile | \u83dc\u9e1f\u6559\u7a0b </li> <li><code>docker-compose.yml</code> \u5b9a\u4e49\u548c\u7ba1\u7406\u4e00\u4e2a\u6216\u591a\u4e2a\u5bb9\u5668 Docker Compose | \u83dc\u9e1f\u6559\u7a0b</li> </ul>"},{"location":"tech/Linux/","title":"Linux","text":""},{"location":"tech/Linux/#_1","title":"\u5e38\u7528\u547d\u4ee4","text":"<p>\u4ec5\u5217\u51fa\u76ee\u524d\u81ea\u5df1\u5e38\u7528\u7684\uff0c\u66f4\u591a\u547d\u4ee4\u53ef\u53c2\u8003 Linux \u547d\u4ee4\u5927\u5168 | \u83dc\u9e1f\u6559\u7a0b </p> <ul> <li><code>cd &lt;\u8def\u5f84&gt;</code> \u5207\u6362\u76ee\u5f55\u5230\u8def\u5f84\u4e0b  </li> <li><code>ls</code> \u5217\u51fa\u5f53\u524d\u8def\u5f84\u4e0b\u7684\u5168\u90e8\u6587\u4ef6\u53ca\u5b50\u76ee\u5f55  </li> <li><code>clear</code> \u6e05\u9664\u7ec8\u7aef\u5c4f\u5e55  </li> <li><code>top</code> \u5b9e\u65f6\u663e\u793a\u670d\u52a1\u5668\u7cfb\u7edf\u548c\u8fdb\u7a0b\u4fe1\u606f</li> </ul>"},{"location":"tech/Python/","title":"Python","text":"<p>\u7b80\u4ecb - Python\u6559\u7a0b - \u5ed6\u96ea\u5cf0\u7684\u5b98\u65b9\u7f51\u7ad9</p>"}]}